# storage backend: local or google
COLOR_MATCH_STORAGE_BACKEND=local

# Local demo paths
COLORBOARD_CSV_PATH=data/colorboard.csv
FORMULA_CSV_PATH=data/formulas.csv
LOCAL_DRIVE_ROOT=data/drive
VECTOR_DIR=data/vectors

# Embedding backend: color_stats for lightweight local demo, openclip for production
EMBEDDING_BACKEND=color_stats
OPENCLIP_MODEL_NAME=ViT-B-32
OPENCLIP_PRETRAINED=openai

# Google mode settings
GOOGLE_SERVICE_ACCOUNT_JSON=
COLORBOARD_SPREADSHEET_ID=
COLORBOARD_WORKSHEET_NAME=ColorBoard
FORMULA_SPREADSHEET_ID=
FORMULA_WORKSHEET_NAME=Formula
GOOGLE_DRIVE_ROOT_FOLDER_ID=
